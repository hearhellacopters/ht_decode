{
  "name": "ht_decode",
  "version": "1.0.0",
  "description": "Android unpacker breakdown.",
  "main": "app.js",
  "scripts": {
    "test_legacy": "node app.js --file ./libs/lib__57d5__legacy.so -o ./output -y --Lv0 0x15AC --Lv1 0x1C50 --Lv2 0x1C0C --Lv3 0x1C0C  > test_legacy.txt",
    "test_64": "node app.js --file ./libs/lib__57d5__64.so -l 572 -o ./output -s0 0x24E68 -e0 0x24E70 -s1 0x192E0 -e1 0x191E0 -s2 0x192E8 -e2 0x191E8 -s3 0x192E8 -e3 0x191E8 -s4 0x192E8 -e4 0x191E8 -s5 0x192E8 -e5 0x191E8 -s6 0x1F300 -e6 0x1F200 -t6 0x1F1F8 -s7 0x192E8 -e7 0x191E8 > test_64.txt",
    "test_64d": "node app.js --file ./libs/libDelta64.so -l 572 -o ./output -s0 0x24E68 -e0 0x24E70 -s1 0x192E0 -e1 0x191E0 -s2 0x192E8 -e2 0x191E8 -s3 0x192E8 -e3 0x191E8 -s4 0x192E8 -e4 0x191E8 -s5 0x192E8 -e5 0x191E8 -s6 0x1F300 -e6 0x1F200 -t6 0x1F1F8 -s7 0x192E8 -e7 0x191E8 > test_64.txt",
    "test_32": "node app.js --file ./libs/lib__57d5__32.so -l 572 -o ./output -s0 0x128B0 -e0 0x128B4 -s1 0x82D4 -e1 0x81D4 -s2 0x82DC -e2 0x81DC -s3 0x82DC -e3 0x81DC -s4 0x82DC -e4 0x81DC -s5 0x82DC -e5 0x81DC -s6 0xB37C -e6 0xB27C -t6 0xB1F0 -o6 0xB1F4 -s7 0x82DC -e7 0x81DC > test_32.txt",
    "test_32d": "node app.js --file ./libs/libDelta.so -l 572 -o ./output -s0 0x128B0 -e0 0x128B4 -s1 0x82D4 -e1 0x81D4 -s2 0x82DC -e2 0x81DC -s3 0x82DC -e3 0x81DC -s4 0x82DC -e4 0x81DC -s5 0x82DC -e5 0x81DC -s6 0xB37C -e6 0xB27C -t6 0xB1F0 -o6 0xB1F4 -s7 0x82DC -e7 0x81DC > test_32.txt",
    "test_data1": "node app.js --file ./libs/data1.dat -o ./output -d > test_data1.txt",
    "test_decodestring": "node app.js --decodestring D65C76DC7C748684B4E476BE648EC6C4 > test_decodestring.txt",
    "test_decodestringlegacy": "node app.js -y -r 1AD171B193F90000 > test_decodestringlegacy.txt",
    "build": "node build.win.js",
    "build:mac:x64": "pkg . --compress GZip --targets node24-macos-x64 -o ht_decode-macos-x64 && codesign --sign - ht_decode-macos-x64",
    "build:mac:arm": "pkg . --compress GZip --targets node24-macos-arm64 -o ht_decode-macos-arm64 && codesign --sign - ht_decode-macos-arm64",
    "build:linux": "pkg . --compress GZip --targets node24-linux-x64 -o ht_decode-linux-x64",
    "build:win": "node build.win.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hearhellacopters/ht_decode.git"
  },
  "author": "hearhellacopters",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hearhellacopters/ht_decode/issues"
  },
  "homepage": "https://github.com/hearhellacopters/ht_decode#readme",
  "devDependencies": {
    "commander": "^12.1.0"
  },
  "dependencies": {
    "@hearhellacopters/exe": "^2.1.5"
  }
}
